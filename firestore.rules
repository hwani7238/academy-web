rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(userDoc(request.auth.uid)) &&
        get(userDoc(request.auth.uid)).data.role in ['admin', 'wonjang', 'siljang'];
    }

    function isApprovedTeacher() {
      return isAuthenticated() &&
        exists(userDoc(request.auth.uid)) &&
        get(userDoc(request.auth.uid)).data.role == 'teacher' &&
        (
          !('status' in get(userDoc(request.auth.uid)).data) ||
          get(userDoc(request.auth.uid)).data.status == 'approved'
        );
    }

    function isStaff() {
      return isAdmin() || isApprovedTeacher();
    }

    function isValidTeacherSignup(userId) {
      return isAuthenticated() &&
        request.auth.uid == userId &&
        !exists(userDoc(userId)) &&
        request.resource.data.keys().hasOnly([
          'email',
          'name',
          'phone',
          'role',
          'status',
          'subject',
          'createdAt',
          'requestedAt'
        ]) &&
        request.resource.data.email is string &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 50 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() <= 30 &&
        request.resource.data.role == 'teacher' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.subject is string &&
        request.resource.data.subject.size() > 0 &&
        request.resource.data.subject.size() <= 30 &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.requestedAt is timestamp;
    }

    match /students/{studentId} {
      allow read, write: if isStaff();

      match /{allChildren=**} {
        allow read, write: if isStaff();
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow read, create, update, delete: if isAdmin();
      allow create: if isValidTeacherSignup(userId);
    }
  }
}
