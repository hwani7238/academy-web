{
  "version": 3,
  "pages404": true,
  "appType": "hybrid",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/report/[studentId]/[logId]",
      "regex": "^/report/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPstudentId": "nxtPstudentId",
        "nxtPlogId": "nxtPlogId"
      },
      "namedRegex": "^/report/(?<nxtPstudentId>[^/]+?)/(?<nxtPlogId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/About",
      "regex": "^/About(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/About(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/api/send-alimtalk",
      "regex": "^/api/send\\-alimtalk(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/send\\-alimtalk(?:/)?$"
    },
    {
      "page": "/Contact",
      "regex": "^/Contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Contact(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/Home",
      "regex": "^/Home(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Home(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/Login",
      "regex": "^/Login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Login(?:/)?$"
    },
    {
      "page": "/News",
      "regex": "^/News(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/News(?:/)?$"
    },
    {
      "page": "/setup-admin",
      "regex": "^/setup\\-admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/setup\\-admin(?:/)?$"
    },
    {
      "page": "/teacher-signup",
      "regex": "^/teacher\\-signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/teacher\\-signup(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}